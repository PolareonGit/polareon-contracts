{
  "name": "polareon-contracts",
  "version": "1.0.0",
  "description": "Polareon smart contracts — ERC-20 token pool & USDC prize vault on Base L2",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PolareonGit/polareon-contracts.git"
  },
  "keywords": ["solidity", "erc20", "base", "token-pool", "vault", "uups"],
  "author": "Polareon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PolareonGit/polareon-contracts/issues"
  },
  "homepage": "https://github.com/PolareonGit/polareon-contracts#readme",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:pool": "hardhat test test/PolareonTokenPool.test.ts",
    "test:vault": "hardhat test test/PolareonVault.test.ts",
    "test:coverage": "hardhat coverage",
    "deploy:pool:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:pool:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:vault:sepolia": "hardhat run scripts/deploy-vault.ts --network baseSepolia",
    "deploy:vault:base": "hardhat run scripts/deploy-vault.ts --network base",
    "upgrade:pool:sepolia": "hardhat run scripts/upgrade.ts --network baseSepolia",
    "upgrade:pool:base": "hardhat run scripts/upgrade.ts --network base",
    "upgrade:vault:sepolia": "hardhat run scripts/upgrade-vault.ts --network baseSepolia",
    "upgrade:vault:base": "hardhat run scripts/upgrade-vault.ts --network base",
    "verify:sepolia": "hardhat run scripts/verify.ts --network baseSepolia",
    "verify:base": "hardhat run scripts/verify.ts --network base",
    "export-abi": "hardhat run scripts/export-abi.ts",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6"
  }
}
