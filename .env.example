# Polareon Contracts — Deployment
# Copy this to .env and fill in values

# Deployer private key (for proxy deployment — typically the Safe multisig proposer or EOA)
DEPLOYER_PRIVATE_KEY=

# Operator EOA private key (backend hot wallet)
OPERATOR_PRIVATE_KEY=

# Safe multisig address (will be set as contract owner)
SAFE_MULTISIG_ADDRESS=

# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Basescan API key for contract verification
BASESCAN_API_KEY=
